```gitignore
# Compiled and binary files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors and IDE
.vscode/
.idea/

# Python specific
*.pyo
*.pyd
.Python
*.so
*.egg-info/

# Coverage reports
.coverage
coverage/
htmlcov/

# Cache directories
.mypy_cache/
.pytest_cache/
.hypothesis/

# OS generated files
.DS_Store
Thumbs.db
```